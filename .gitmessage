# 커밋 메시지 템플릿

<type>(<scope>): <subject>

<body>

<footer>

# Type:
#   feat: 새로운 기능
#   fix: 버그 수정
#   docs: 문서 수정
#   style: 코드 포맷팅
#   refactor: 리팩토링
#   test: 테스트 추가/수정
#   chore: 빌드 설정, 의존성 등

# Scope:
#   grpc, broker, config 등

# Subject:
#   간단한 한 줄 요약 (50자 이내)

# Body:
#   변경 사항 상세 설명

# Footer:
#   관련 이슈 번호 (Closes #123, Fixes #456)

